# ─── Base de données (Supabase PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ─── JWT (signature des cookies de session) ────────────────────────────────────
JWT_SECRET=une-chaine-aleatoire-longue-et-secrete

# ─── Supabase Storage (photos profil + CVs) ────────────────────────────────────
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── OpenAI (extraction IA des CVs) ────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Email transactionnel (Resend) — optionnel ─────────────────────────────────
RESEND_API_KEY=re_...

# ─── CORS — origines autorisées (séparées par virgule) ─────────────────────────
# En développement : laisser vide (localhost autorisé par défaut)
# En production : mettre l'URL Vercel de ton frontend
CORS_ORIGIN=https://cameroon-travail.vercel.app

# ─── Identifiant de l'application (utilisé pour les cookies) ───────────────────
VITE_APP_ID=cameroon-travail

# ─── [Vercel uniquement] URL du backend Railway ────────────────────────────────
# VITE_API_URL=https://your-server.railway.app
