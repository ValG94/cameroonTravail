# ─── Serveur ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Base de données — Supabase PostgreSQL ───────────────────────────────────
# Récupérer dans : Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.[REF_PROJET].supabase.co:5432/postgres

# ─── Supabase ────────────────────────────────────────────────────────────────
# Récupérer dans : Supabase → Settings → API
SUPABASE_URL=https://[REF_PROJET].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...     # ⚠️ Ne jamais exposer côté frontend
SUPABASE_ANON_KEY=sb_publishable_...

# ─── JWT — générer avec : node -e "require('crypto').randomBytes(64).toString('hex')" ──
JWT_SECRET=<générer_une_valeur_aléatoire_64_chars>
JWT_REFRESH_SECRET=<générer_une_valeur_aléatoire_64_chars>
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
JWT_ISSUER=cameroon-travail
JWT_AUDIENCE=cameroon-travail-users

# ─── CORS ────────────────────────────────────────────────────────────────────
# URL(s) Vercel autorisées — plusieurs séparées par des virgules :
# CORS_ORIGIN=https://cameroon-travail.vercel.app,https://mon-preview.vercel.app
CORS_ORIGIN=https://[TON_PROJET].vercel.app

# ─── OpenAI (extraction automatique de CV) ───────────────────────────────────
OPENAI_API_KEY=sk-proj-...
