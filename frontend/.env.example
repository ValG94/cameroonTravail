# ─── URL du backend ──────────────────────────────────────────────────────────
# En développement local :
# VITE_API_URL=http://localhost:3001
# En production (Railway) :
VITE_API_URL=https://[TON_BACKEND].up.railway.app

# ─── Supabase (clés publiques uniquement) ────────────────────────────────────
# Récupérer dans : Supabase → Settings → API
VITE_SUPABASE_URL=https://[REF_PROJET].supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ⚠️ Ne JAMAIS mettre DATABASE_URL ou SUPABASE_SERVICE_ROLE_KEY ici.
#    Ces clés sont réservées au backend (Railway).
